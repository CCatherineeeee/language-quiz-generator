# Copy to .env and fill in. .env is gitignored — never commit real values.

# Neon Postgres connection string (postgres:// or postgresql:// both work)
DATABASE_URL=postgresql://user:password@host/dbname

# Shared secret for the owner account login (decision log #5)
OWNER_SECRET=pick-a-long-random-string

# LLM provider keys — any subset; the fallback chain skips missing ones (decision log)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
